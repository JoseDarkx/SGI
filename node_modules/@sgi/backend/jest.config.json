{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts", "**/*.test.ts"],
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/../shared/$1"
  },
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", {
      "tsconfig": {
        "module": "commonjs",
        "esModuleInterop": true
      }
    }]
  },
  "setupFiles": ["<rootDir>/src/test/setup.ts"],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/index.ts",
    "!src/test/**"
  ],
  "coverageReporters": ["text", "html"]
}
