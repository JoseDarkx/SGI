
# ============================================================
# Variables de entorno — Frontend SGI
# Copia este archivo como .env y completa los valores reales.
# NUNCA agregues claves privadas (service_role, etc.) aquí.
# ============================================================

# URL pública del proyecto Supabase
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave anónima del proyecto (pública, segura para el navegador)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# API Key de Gemini (Google AI)
VITE_GEMINI_API_KEY=tu-gemini-key-aqui

# URL del backend Express
# - Desarrollo:  http://localhost:3001/api
# - Producción:  https://tu-backend.onrender.com/api
VITE_API_URL=https://tu-backend.onrender.com/api